  m_Script: {fileID: 11500000, guid: 4e0c74d5342224548b26c4eb21ffb264, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::QuizManager3D
  questionLabel: {fileID: 4026789011577444290}
  cubeButtons:
  - {fileID: 2624630640336928514}
  - {fileID: 6848510878985610037}
  - {fileID: 5155674293297638161}
  - {fileID: 7182861234985259662}
  spawnPoints:
  - {fileID: 1963021459604854533}
  - {fileID: 222984369589961475}
  - {fileID: 2722501336669773035}
  - {fileID: 7003251601887451635}
  questions:
  - questionText: "\u041A\u0430\u043A\u043E\u0433\u043E \u0440\u0430\u0437\u043C\u0435\u0440\u0430
      \u043F\u043B\u0430\u043D\u0435\u0442\u0430 \u041C\u0435\u0440\u043A\u0443\u0440\u0438\u0439
      \u043F\u043E \u0441\u0440\u0430\u0432\u043D\u0435\u043D\u0438\u044E \u0441
      \u0434\u0440\u0443\u0433\u0438\u043C\u0438 \u043F\u043B\u0430\u043D\u0435\u0442\u0430\u043C\u0438
      \u0421\u043E\u043B\u043D\u0435\u0447\u043D\u043E\u0439 \u0441\u0438\u0441\u0442\u0435\u043C\u044B?"
    answers:
    - "\u0421\u0430\u043C\u0430\u044F \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F"
    - "\u0421\u0430\u043C\u0430\u044F \u0431\u043E\u043B\u044C\u0448\u0430\u044F"
    - "\u0422\u0430\u043A\u0430\u044F \u0436\u0435, \u043A\u0430\u043A \u0417\u0435\u043C\u043B\u044F"
    - "\u041D\u0435 \u0441\u043C\u043E\u0433\u043B\u0438 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u0438\u0442\u044C"
  - questionText: "\u0427\u0442\u043E \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
      \u043D\u0430 \u043F\u043E\u0432\u0435\u0440\u0445\u043D\u043E\u0441\u0442\u0438
      \u043F\u043B\u0430\u043D\u0435\u0442\u044B?"
    answers:
    - "\u041A\u0440\u0430\u0442\u0435\u0440\u044B"
    - "\u0412\u0443\u043B\u043A\u0430\u043D\u044B"
    - "\u0412\u043E\u0434\u0430"
    - "\u041B\u0451\u0434"
  - questionText: "\u042D\u0442\u0430 \u043F\u043B\u0430\u043D\u0435\u0442\u0430
      \u0433\u043E\u0440\u044F\u0447\u0430\u044F \u0438\u043B\u0438 \u0445\u043E\u043B\u043E\u0434\u043D\u0430\u044F?"
    answers:
    - "\u0413\u043E\u0440\u044F\u0447\u0430\u044F \u0434\u043D\u0451\u043C, \u0445\u043E\u043B\u043E\u0434\u043D\u0430\u044F
      \u043D\u043E\u0447\u044C\u044E"
    - "\u0413\u043E\u0440\u044F\u0447\u0430\u044F \u043D\u043E\u0447\u044C\u044E,
      \u0445\u043E\u043B\u043E\u0434\u043D\u0430\u044F \u0434\u043D\u0451\u043C"
    - "\u0413\u043E\u0440\u044F\u0447\u0430\u044F"
    - "\u0425\u043E\u043B\u043E\u0434\u043D\u0430\u044F"
  - questionText: "\u041F\u043E\u0441\u0435\u0449\u0430\u043B\u0438 \u043B\u0438
      \u043B\u044E\u0434\u0438 \u043F\u043B\u0430\u043D\u0435\u0442\u0443?"
    answers:
    - "\u041F\u043E\u0441\u0435\u0449\u0430\u043B\u0438 \u0442\u043E\u043B\u044C\u043A\u043E
      \u0441\u043F\u0443\u0442\u043D\u0438\u043A\u0438"
    - "\u042F \u043F\u043E\u0441\u0435\u0449\u0430\u043B"
    - "\u041D\u0435\u0442"
    - "\u0414\u0430"
  - questionText: "\u0415\u0441\u0442\u044C \u043B\u0438 \u0436\u0438\u0437\u043D\u044C
      \u043D\u0430 \u041C\u0435\u0440\u043A\u0443\u0440\u0438\u0438?"
    answers:
    - "\u041D\u0435\u0442"
    - "\u0414\u0430"
